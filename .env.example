DATABASE_URL="postgresql://user:password@localhost:5432/newcap_crm?schema=public"

# Server-side only — never exposed to the client.
ANTHROPIC_API_KEY=""
HUNTER_API_KEY=""

# Google OAuth (Gmail send + Calendar) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Microsoft OAuth (Outlook send + Calendar) — https://portal.azure.com
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/auth/microsoft/callback"
MICROSOFT_TENANT_ID="common"

# Session/JWT signing secret — replace in production.
AUTH_SECRET="replace-with-a-long-random-string"

# Encryption key for OAuth tokens & Hunter key at rest (32-byte hex).
TOKEN_ENCRYPTION_KEY="replace-with-openssl-rand--hex-32-output"

NODE_ENV="development"
